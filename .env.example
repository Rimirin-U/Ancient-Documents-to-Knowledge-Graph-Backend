# 文渊智图 · 后端环境变量配置
#
# 使用方法：
#   1. 复制本文件为 .env（与 main.py 同级目录）
#   2. 填写必填项，按需修改可选项
#   3. 启动服务前确保 .env 文件已就绪
#
# 注意：请勿将包含真实密钥的 .env 文件提交到版本库

# ============ 必填 ============

# JWT 签名密钥（请替换为足够长的随机字符串）
SECRET_KEY=请替换为足够长的随机字符串

# ============ 可选 ============

# 阿里云 DashScope API 密钥（OCR、结构化、问答等 AI 功能所需）
# DASHSCOPE_API_KEY=

# Redis 配置（Celery 任务队列依赖）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# 服务端口
# SERVER_PORT=3000

# 图片存储目录
# UPLOAD_DIR=pic

# 数据库连接（默认使用 SQLite: database/app.db）
# DATABASE_URL=
